    {
      "name": "retourner la liste des livres",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "let books = pm.response.json();\r",
              "console.log(books)\r",
              "\r",
              "pm.test(\"Liste non vide\", function () {\r",
              "    pm.expect(books.length).to.be.above(0);\r",
              "});\r",
              "// Stocker l'id du premier livre\r",
              "pm.environment.set(\"idBook\",books[0].id)"
